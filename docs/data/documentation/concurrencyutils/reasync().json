        },
        {
          "code" : [
            "\/\/ Source",
            "@Reasync",
            "func withFoo<E: Error, R: ~Copyable>(",
            "  operation: (Foo) throws(E) -> R",
            ") throws(E) -> R {",
            "  return try operation(foo)",
            "}",
            "",
            "\/\/ Result",
            "func withFoo<E: Error, R: ~Copyable>(",
            "  operation: (Foo) throws(E) -> R",
            ") throws(E) -> R {",
            "  return try operation(foo)",
            "}",
            "",
            "nonisolated(nonsending)",
            "func withFoo<E: Error, R: ~Copyable>(",
            "  operation: nonisolated(nonsending) (Foo) async throws(E) -> R",
            ") async throws(E) -> R {",
            "  return try await operation(foo)",
